# ── AI provider (set ONE, matching config.yaml -> llm.provider) ──
# Default provider is Anthropic (paid). For FREE, fill in one of the others
# and set llm.provider in config.yaml to match.
ANTHROPIC_API_KEY=sk-ant-...          # provider: anthropic
OPENROUTER_API_KEY=                    # provider: openrouter (openrouter.ai/keys — has free models)
GROQ_API_KEY=                          # provider: groq    (console.groq.com/keys)
NVIDIA_API_KEY=                        # provider: nvidia  (build.nvidia.com)
GEMINI_API_KEY=                        # provider: gemini  (aistudio.google.com/apikey)
# OPENAI_API_KEY=                      # provider: openai  (or any OpenAI-compatible host)
# OPENAI_BASE_URL=                     # provider: openai  (the host's base URL)
# (ollama needs no key — just run it locally)

# YouTube upload (OAuth client secrets file path). Get from Google Cloud Console:
# APIs & Services > Credentials > OAuth client ID (Desktop app)
YOUTUBE_CLIENT_SECRETS=client_secret.json

# Optional: TikTok Content Posting API (requires approved app)
TIKTOK_ACCESS_TOKEN=

# Optional: Instagram Graph API (Business account)
IG_ACCESS_TOKEN=
IG_USER_ID=

# Optional: free Pexels key for stock photo/video b-roll overlays
# (config.yaml -> editor.broll). Get one at https://www.pexels.com/api/
PEXELS_API_KEY=
